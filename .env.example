# OQA System - Environment Configuration
# Copy this file to .env and fill in your values

SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for dev, switch for prod)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# For MySQL / Postgres examples:
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=oqa
# DB_USER=root
# DB_PASSWORD=secret
# DB_HOST=localhost
# DB_PORT=3306

# Email (used for future notifications; console backend in DEBUG)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Optional: Timezone already set to Africa/Dar_es_Salaam in settings
